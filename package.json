{
  "name": "ai-research-orchestrator",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=22"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "error"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{json,md}\" \".github/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{json,md}\" \".github/**/*.md\"",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "prepare": "husky",
    "predeploy": "pnpm run build"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.19.0",
    "@reduxjs/toolkit": "^2.2.5",
    "@tanstack/react-virtual": "^3.13.21",
    "chart.js": "^4.4.3",
    "cmdk": "^1.1.1",
    "dexie": "^4.0.7",
    "dexie-react-hooks": "^1.1.7",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.35.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "marked": "^13.0.2",
    "react": "^19.1.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.1.2",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fake-indexeddb": "^6.0.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
