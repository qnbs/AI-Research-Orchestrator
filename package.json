{
  "name": "ai-research-orchestrator",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.12.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/patch-csp-hashes.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 650",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{json,md}\" \".github/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{json,md}\" \".github/**/*.md\"",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "workbox:copy": "node scripts/copy-workbox.mjs",
    "prepare": "husky",
    "predeploy": "pnpm run build",
    "analyze": "ANALYZE=1 vite build && node scripts/patch-csp-hashes.mjs",
    "bundle:budget": "node scripts/check-bundle-budget.mjs",
    "check:no-cdn-scripts": "node scripts/check-no-cdn-scripts.mjs",
    "check:workbox-vendor-drift": "node scripts/check-workbox-vendor-drift.mjs",
    "i18n:ratchet": "node scripts/check-i18n-ratchet.mjs",
    "csp:hashes": "node scripts/patch-csp-hashes.mjs",
    "test:lighthouse": "pnpm run build && pnpm exec lhci autorun"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 650",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@google/genai": "^1.52.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tanstack/react-virtual": "^3.13.21",
    "cmdk": "^1.1.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^1.1.7",
    "dompurify": "^3.4.12",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^1.14.0",
    "marked": "^13.0.2",
    "openai": "^4.104.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-redux": "^9.1.2",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.16.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.7",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.6",
    "rollup-plugin-visualizer": "^6.0.11",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.2",
    "vite": "8.1.5",
    "vitest": "^3.2.7",
    "workbox-cacheable-response": "7.0.0",
    "workbox-core": "7.0.0",
    "workbox-expiration": "7.0.0",
    "workbox-precaching": "7.0.0",
    "workbox-routing": "7.0.0",
    "workbox-strategies": "7.0.0",
    "workbox-sw": "7.0.0"
  }
}
